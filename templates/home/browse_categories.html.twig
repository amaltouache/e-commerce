<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Our Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<!-- Header -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="#">Our Store</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Products</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Cart</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Profile</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<div class="bg-primary bg-gradient text-white py-5">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-4">Welcome to Our Store</h1>
                <p class="lead mb-4">
                    Discover amazing products across all categories. Quality items at unbeatable prices.
                </p>

                <a href="#" class="btn btn-light btn-lg me-2">Shop Now</a>
                <a href="#categories" class="btn btn-outline-light btn-lg">Browse Categories</a>
            </div>

            <div class="col-lg-6 text-center">
                <img src="https://via.placeholder.com/500x400" class="img-fluid rounded" alt="Shopping">
            </div>

        </div>
    </div>
</div>

<!-- Categories Section (DYNAMIC) -->
<div class="container my-5" id="categories">

    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold">Shop by Category</h2>
        <p class="text-muted">Explore our wide range of products organized by category</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

        {% for category in categories %}

            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">

                        <h4 class="card-title">{{ category.name }}</h4>

                        <p class="card-text text-muted">
                            {{ category.description ?? 'No description' }}
                        </p>

                        <a href="{{ path('products_by_category', {id: category.id}) }}"
                           class="btn btn-outline-primary">
                            Voir Produits
                        </a>

                    </div>
                </div>
            </div>

        {% endfor %}

    </div>
</div>

<!-- Features Section (UNCHANGED) -->
<div class="bg-light py-5 mt-5">
    <div class="container">
        <div class="row text-center">

            <div class="col-md-4 mb-4">
                <h5>Free Shipping</h5>
                <p class="text-muted">On orders over $50</p>
            </div>

            <div class="col-md-4 mb-4">
                <h5>Secure Payment</h5>
                <p class="text-muted">100% secure transactions</p>
            </div>

            <div class="col-md-4 mb-4">
                <h5>Easy Returns</h5>
                <p class="text-muted">30-day return policy</p>
            </div>

        </div>
    </div>
</div>

<!-- Footer -->
<footer class="bg-dark text-white mt-5 py-4">
    <div class="container">
        <div class="row">

            <div class="col-md-6">
                <h5>Our Store</h5>
                <p>Quality products at affordable prices</p>
            </div>

            <div class="col-md-6 text-md-end">
                <p>&copy; 2024 Our Store. All rights reserved.</p>
            </div>

        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>