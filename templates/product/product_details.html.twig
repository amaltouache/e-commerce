<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ product.name }} - Our Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<!-- Header -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="#">Our Store</a>

        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="#">Products</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Cart</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Product Details -->
<div class="container my-5">
    <div class="row">

        <!-- Image -->
        <div class="col-md-6">
            <img src="{{ asset('images/airbod.png') }}"
                 class="img-fluid rounded"
                 alt="{{ product.name }}">
        </div>

        <!-- Info -->
        <div class="col-md-6">

            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item">
                        <a href="#" class="text-decoration-none">
                            {{ product.category.name ?? 'Category' }}
                        </a>
                    </li>
                    <li class="breadcrumb-item active">{{ product.name }}</li>
                </ol>
            </nav>

            <span class="badge bg-primary mb-3">
                {{ product.category.name ?? 'Uncategorized' }}
            </span>

            <h1 class="mb-3">{{ product.name }}</h1>

            <h3 class="text-success mb-4">
                {{ product.price }} DH
            </h3>

            <div class="mb-4">
                <h5>Description</h5>
                <p class="text-muted">
                    {{ product.description ?? 'No description available.' }}
                </p>
            </div>

            <!-- Add to Cart -->
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input type="number"
                           name="quantity"
                           value="1"
                           min="1"
                           max="10"
                           class="form-control"
                           style="max-width: 100px;">
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Add to Cart
                    </button>

                    <a href="{{ path('home') }}" class="btn btn-outline-secondary btn-lg">
                        Continue Shopping
                    </a>
                </div>
            </form>

            <!-- Info -->
            <div class="mt-4 pt-4 border-top">
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <strong>SKU:</strong> {{ product.id }}
                    </li>

                    <li class="mb-2">
                        <strong>Availability:</strong>
                        <span class="text-success">In Stock</span>
                    </li>

                    <li class="mb-2">
                        <strong>Category:</strong>
                        {{ product.category.name ?? 'None' }}
                    </li>
                </ul>
            </div>

        </div>
    </div>
</div>

<!-- Footer -->
<footer class="bg-dark text-white mt-5 py-4">
    <div class="container text-center">
        <h5>Our Store</h5>
        <p>Quality products at affordable prices</p>
        <p>&copy; 2026 Our Store. All rights reserved.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>